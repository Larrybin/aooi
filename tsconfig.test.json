{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "tsBuildInfoFile": ".next/cache/tsconfig.test.tsbuildinfo"
  },
  "include": [
    "next-env.d.ts",
    "src/shared/types/**/*.d.ts",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "tests/**/*.ts",
    "tests/**/*.tsx",
    "scripts/**/*.test.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "out",
    "dist",
    "raphael-starterkit-v1-main"
  ]
}
