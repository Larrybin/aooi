  "faq": {
    "id": "pricing-faq",
    "title": "Pricing questions before you upgrade.",
    "items": [
      {
        "question": "Can I use Background Remover for free?",
        "answer": "Yes. Guests can remove a small number of backgrounds each day, and signed-in free users get a higher daily limit."
      },
      {
        "question": "Do exports have transparent backgrounds?",
        "answer": "Yes. Results are delivered as transparent PNG files."
      },
      {
        "question": "What happens when I cancel?",
        "answer": "Subscription benefits downgrade at the end of the active billing period. Your image retention and quota limits return to the free plan."
      },
      {
        "question": "What formats can I upload?",
        "answer": "The V1 product supports PNG, JPG, JPEG, and WebP uploads."
      }
    ]
  }
