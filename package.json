    "rough-notation": "^0.5.1",
    "server-only": "^0.0.1",
    "shiki": "^3.19.0",
    "simple-flakeid": "^0.0.5",
    "sonner": "^2.0.7",
    "streamdown": "^1.4.0",
    "stripe": "^18.5.0",
    "swiper": "^12.0.1",
    "tailwind-merge": "^3.3.1",
