{
  "name": "roller-rabbit",
  "version": "1.2.0",
  "private": true,
  "author": "Larrybin",
  "homepage": "https://github.com/Larrybin/aooi",
  "repository": {
    "type": "git",
    "url": "https://github.com/Larrybin/aooi.git"
  },
  "keywords": [
    "ai-saas-boilerplate",
    "ai-saas-template",
    "ai-saas-framework",
    "ai-saas-development"
  ],
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "node scripts/next-build.mjs",
    "build:fast": "node scripts/next-build.mjs --max-old-space-size=4096",
    "start": "next start",
    "test": "node scripts/run-tests.mjs",
    "test:auth-spike": "node --import tsx scripts/run-auth-spike.mjs",
    "test:local-auth-spike": "node --import tsx scripts/run-local-auth-spike.mjs",
    "test:cf-auth-spike": "node --import tsx scripts/run-cf-auth-spike.mjs",
    "test:cf-oauth-spike": "node --import tsx scripts/run-cf-oauth-spike.mjs",
    "test:cf-preview-smoke": "node scripts/run-cf-preview-smoke.mjs",
    "test:cf-app-smoke": "node --import tsx scripts/run-cf-app-smoke.mjs",
    "test:creem-webhook-spike": "node --test --import tsx \"src/extensions/payment/creem.test.ts\" \"tests/contract/payment-notify.test.ts\"",
    "test:r2-upload-spike": "node --test --import tsx \"src/app/api/storage/upload-image/route.test.ts\"",
    "test:coverage": "node scripts/run-tests.mjs --coverage",
    "lint": "eslint . --report-unused-disable-directives",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "conventions:draft": "node scripts/conventions-index.mjs --out .codex/drafts/CONVENTIONS.generated.md",
    "conventions:check": "node scripts/conventions-index.mjs --check",
    "db:generate": "npx drizzle-kit generate --config=src/core/db/config.ts",
    "db:migrate": "npx drizzle-kit migrate --config=src/core/db/config.ts",
    "db:check": "npx tsx scripts/check-db-schema.ts",
    "db:push": "npx drizzle-kit push --config=src/core/db/config.ts",
    "db:studio": "npx drizzle-kit studio --config=src/core/db/config.ts",
    "auth:generate": "npx @better-auth/cli generate --config=src/core/auth/index.ts",
    "rbac:init": "npx tsx scripts/init-rbac.ts",
    "rbac:assign": "npx tsx scripts/assign-role.ts",
    "postinstall": "fumadocs-mdx",
    "cf:check": "node scripts/check-cloudflare-config.mjs",
    "cf:check:deploy": "node scripts/check-cloudflare-config.mjs --deploy",
    "cf:build": "opennextjs-cloudflare build --config wrangler.cloudflare.toml",
    "cf:preview": "pnpm cf:check && pnpm cf:build && opennextjs-cloudflare preview --config wrangler.cloudflare.toml",
    "cf:deploy": "pnpm cf:check && pnpm cf:check:deploy && pnpm cf:build && opennextjs-cloudflare deploy --config wrangler.cloudflare.toml",
    "cf:upload": "pnpm cf:check && pnpm cf:check:deploy && pnpm cf:build && opennextjs-cloudflare upload --config wrangler.cloudflare.toml",
    "cf:typegen": "wrangler types --config wrangler.cloudflare.toml --env-interface CloudflareEnv src/shared/types/cloudflare.d.ts"
  },
  "dependencies": {
    "@ai-sdk/react": "^2.0.89",
    "@ai-sdk/replicate": "^1.0.8",
    "@better-fetch/fetch": "^1.1.18",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
